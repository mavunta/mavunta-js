{
  "name": "@mavunta/react",
  "version": "1.1.1",
  "description": "React components and hooks for Mavunta Pay checkout (M-Pesa, card, PayPal, crypto).",
  "license": "MIT",
  "author": "Chainwaka Technologies",
  "homepage": "https://developers.mavunta.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mavunta/mavunta-js.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/mavunta/mavunta-js/issues"
  },
  "keywords": [
    "mavunta",
    "mavunta-pay",
    "react",
    "checkout",
    "mpesa",
    "kenya",
    "payments",
    "crypto"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rimraf dist",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run test && npm run build && npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@mavunta/checkout-js": "workspace:^1.1.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
